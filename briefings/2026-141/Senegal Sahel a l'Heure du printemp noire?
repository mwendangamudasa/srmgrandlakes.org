<script>
function PN(cv,o){
  const O=Object.assign({n:55,sp:.25,ll:130,col:'rgba(201,168,76,'},o);
  const x=cv.getContext('2d');let W,H,pts=[],raf;
  function rsz(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  function mk(){return{x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*O.sp,vy:(Math.random()-.5)*O.sp,r:1.5+Math.random()*.8};}
  function init(){rsz();pts=[];for(let i=0;i<O.n;i++)pts.push(mk());}
  function draw(){
    x.clearRect(0,0,W,H);
    pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<-20)p.x=W+20;if(p.x>W+20)p.x=-20;if(p.y<-20)p.y=H+20;if(p.y>H+20)p.y=-20;
      x.beginPath();x.arc(p.x,p.y,p.r,0,Math.PI*2);x.fillStyle=O.col+'0.48)';x.fill();});
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
      const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<O.ll){x.beginPath();x.moveTo(pts[i].x,pts[i].y);x.lineTo(pts[j].x,pts[j].y);x.strokeStyle=O.col+(1-d/O.ll)*.24+')';x.lineWidth=.5;x.stroke();}}
    raf=requestAnimationFrame(draw);}
  function start(){init();draw();}
  window.addEventListener('resize',()=>{rsz();pts=[];for(let i=0;i<O.n;i++)pts.push(mk());});
  return{start};
}
function HexBg(cv){
  const x=cv.getContext('2d');let W,H;
  function rsz(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  function draw(){x.clearRect(0,0,W,H);const s=40,w=s*2,h=Math.sqrt(3)*s;
    for(let r=-1;r<H/h+2;r++)for(let c=-1;c<W/w+2;c++){
      const ox=(r%2===0)?0:w*.75,cx=c*w*1.5+ox,cy=r*h+(r%2===0?0:h*.5);
      x.beginPath();for(let i=0;i<6;i++){const a=Math.PI/180*(60*i-30);i===0?x.moveTo(cx+s*Math.cos(a),cy+s*Math.sin(a)):x.lineTo(cx+s*Math.cos(a),cy+s*Math.sin(a));}
      x.closePath();x.strokeStyle='rgba(201,168,76,.05)';x.lineWidth=.5;x.stroke();}}
  rsz();draw();window.addEventListener('resize',()=>{rsz();draw();});}
function Ripple(cv,col='200,48,58'){
  const x=cv.getContext('2d');let W,H,raf;
  function rsz(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  function draw(){x.clearRect(0,0,W,H);const t=Date.now()/1000,cx=W*.15,cy=H*.72;
    for(let i=0;i<7;i++){const ph=((t*.2+i/7)%1),r=ph*Math.max(W,H)*.95,a=(1-ph)*.09;
      x.beginPath();x.arc(cx,cy,r,0,Math.PI*2);x.strokeStyle=`rgba(${col},${a})`;x.lineWidth=.8;x.stroke();}
    raf=requestAnimationFrame(draw);}
  rsz();draw();window.addEventListener('resize',rsz);}
function DiagLn(cv){
  const x=cv.getContext('2d');let W,H,raf;
  function rsz(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  function draw(){x.clearRect(0,0,W,H);const t=Date.now()/2200;
    x.save();x.translate(W*.5,H*.5);x.rotate(-.3);
    for(let i=-22;i<22;i++){const off=((i*58+t*58*.1)%(58*2))-58;x.beginPath();x.moveTo(-W,off);x.lineTo(W,off);x.strokeStyle='rgba(201,168,76,.04)';x.lineWidth=.5;x.stroke();}
    x.restore();raf=requestAnimationFrame(draw);}
  rsz();draw();window.addEventListener('resize',rsz);}
function RadGrid(cv){
  const x=cv.getContext('2d');let W,H;
  function rsz(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  function draw(){x.clearRect(0,0,W,H);const cx=W*.5,cy=H*.5;
    for(let r=50;r<Math.max(W,H);r+=52){x.beginPath();x.arc(cx,cy,r,0,Math.PI*2);x.strokeStyle='rgba(201,168,76,.038)';x.lineWidth=.5;x.stroke();}
    for(let a=0;a<360;a+=18){const ra=a*Math.PI/180;x.beginPath();x.moveTo(cx,cy);x.lineTo(cx+Math.cos(ra)*Math.max(W,H),cy+Math.sin(ra)*Math.max(W,H));x.strokeStyle='rgba(201,168,76,.026)';x.lineWidth=.5;x.stroke();}}
  rsz();draw();window.addEventListener('resize',()=>{rsz();draw();});}
function Star(cv){
  const x=cv.getContext('2d');let W,H,raf;
  function rsz(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  function draw(){x.clearRect(0,0,W,H);const t=Date.now()/9000,cx=W*.5,cy=H*.55;
    for(let i=0;i<36;i++){const a=(i/36)*Math.PI*2+t,l=H*.62+Math.sin(t*3+i)*(H*.05);x.beginPath();x.moveTo(cx,cy);x.lineTo(cx+Math.cos(a)*l,cy+Math.sin(a)*l);x.strokeStyle='rgba(201,168,76,.038)';x.lineWidth=.5;x.stroke();}
    raf=requestAnimationFrame(draw);}
  rsz();draw();window.addEventListener('resize',rsz);}
window.addEventListener('load',()=>{
  PN(document.getElementById('c0'),{n:65,sp:.22,ll:145,col:'rgba(184,74,40,'}).start();
  HexBg(document.getElementById('c1'));
  Ripple(document.getElementById('c2'),'184,74,40');
  DiagLn(document.getElementById('c3'));
  Ripple(document.getElementById('c4'));
  RadGrid(document.getElementById('c5'));
  RadGrid(document.getElementById('c6'));
  Star(document.getElementById('c7'));
});
const slides=document.querySelectorAll('.slide'),total=slides.length;let cur=0;
function goTo(n){if(n<0||n>=total)return;slides[cur].classList.remove('active');slides[cur].classList.add('exit');setTimeout(()=>slides[cur].classList.remove('exit'),700);cur=n;slides[cur].classList.add('active');upd();}
function upd(){document.getElementById('pb').style.width=((cur+1)/total*100)+'%';document.getElementById('sn').textContent=String(cur+1).padStart(2,'0')+' / '+String(total).padStart(2,'0');document.querySelectorAll('.dot').forEach((d,i)=>d.classList.toggle('active',i===cur));}
function buildDots(){const c=document.getElementById('nd');for(let i=0;i<total;i++){const d=document.createElement('div');d.className='dot'+(i===0?' active':'');d.addEventListener('click',()=>goTo(i));c.appendChild(d);}}
document.getElementById('prev').addEventListener('click',()=>goTo(cur-1));
document.getElementById('next').addEventListener('click',()=>goTo(cur+1));
document.addEventListener('keydown',e=>{if(e.key==='ArrowRight'||e.key==='ArrowDown')goTo(cur+1);if(e.key==='ArrowLeft'||e.key==='ArrowUp')goTo(cur-1);});
let ts=0,tx=0;
document.addEventListener('touchstart',e=>{ts=e.touches[0].clientY;tx=e.touches[0].clientX;},{passive:true});
document.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx,dy=e.changedTouches[0].clientY-ts;if(Math.abs(dx)>Math.abs(dy)){if(dx<-50)goTo(cur+1);else if(dx>50)goTo(cur-1);}},{passive:true});
setTimeout(()=>{const h=document.getElementById('kh');if(h)h.style.opacity='0';},4000);
buildDots();upd();
</script>
