<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SRM | Sénégal — Fracture au Sommet & Implications Régionales · 23 Mai 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;0,700;1,300;1,600&family=IBM+Plex+Mono:wght@300;400;500&family=Barlow+Condensed:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --ink:#010d18;--navy:#04101e;--gold:#c9a84c;--gold2:#e8c56a;
  --white:#f2ede4;--muted:#6b87a8;--red:#c8303a;--amber:#c97b06;
  --green:#0d7a4a;--terracotta:#b84a28;
}
html,body{width:100%;height:100%;overflow:hidden;background:var(--ink);font-family:'Barlow Condensed',sans-serif;}
canvas.bgc{position:absolute;inset:0;width:100%;height:100%;z-index:0;}

/* DECK */
.deck{position:relative;width:100%;height:100%;}
.slide{position:absolute;inset:0;display:flex;flex-direction:column;opacity:0;pointer-events:none;overflow:hidden;
  transition:opacity .7s cubic-bezier(.4,0,.2,1),transform .7s cubic-bezier(.4,0,.2,1);
  transform:translateX(80px) scale(0.98);}
.slide.active{opacity:1;pointer-events:all;transform:translateX(0) scale(1);}
.slide.exit{opacity:0;transform:translateX(-80px) scale(0.98);}
.slide::after{content:'';position:absolute;inset:0;z-index:2;pointer-events:none;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.05) 3px,rgba(0,0,0,.05) 4px);}

/* CONTENT */
.si{position:relative;z-index:3;flex:1;display:flex;flex-direction:column;padding:34px 52px 30px;}

/* CORNER BRACKETS */
.bk{position:absolute;z-index:4;width:24px;height:24px;pointer-events:none;}
.bk-tl{top:14px;left:14px;border-top:1px solid rgba(201,168,76,.45);border-left:1px solid rgba(201,168,76,.45);}
.bk-tr{top:14px;right:14px;border-top:1px solid rgba(201,168,76,.45);border-right:1px solid rgba(201,168,76,.45);}
.bk-bl{bottom:54px;left:14px;border-bottom:1px solid rgba(201,168,76,.45);border-left:1px solid rgba(201,168,76,.45);}
.bk-br{bottom:54px;right:14px;border-bottom:1px solid rgba(201,168,76,.45);border-right:1px solid rgba(201,168,76,.45);}

/* GHOST TEXT */
.ghost{position:absolute;z-index:1;font-family:'Cormorant Garamond',serif;font-weight:700;line-height:.85;
  color:transparent;-webkit-text-stroke:1px rgba(201,168,76,.06);pointer-events:none;user-select:none;
  text-transform:uppercase;white-space:nowrap;}

/* TOPBAR */
.tb{display:flex;justify-content:space-between;align-items:center;
  padding-bottom:14px;border-bottom:1px solid rgba(201,168,76,.18);margin-bottom:24px;}
.tb-b{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.22em;color:var(--gold);text-transform:uppercase;}
.tb-m{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:.1em;}

/* NAV & PROGRESS */
.progress-bar{position:absolute;bottom:0;left:0;height:2px;background:linear-gradient(90deg,var(--terracotta),var(--gold));transition:width .6s ease;z-index:10;}
.nav{position:absolute;bottom:17px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:13px;z-index:20;}
.nav-btn{width:34px;height:34px;border-radius:50%;background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.25);
  color:var(--gold);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;
  transition:background .2s,transform .15s;user-select:none;}
.nav-btn:hover{background:rgba(201,168,76,.2);transform:scale(1.1);}
.dot{width:5px;height:5px;border-radius:50%;background:rgba(201,168,76,.22);cursor:pointer;transition:all .3s;}
.dot.active{background:var(--gold);transform:scale(1.5);}
.snum{position:absolute;bottom:21px;right:40px;z-index:20;font-family:'IBM Plex Mono',monospace;font-size:9px;color:rgba(201,168,76,.32);letter-spacing:.15em;}
.kh{position:absolute;top:17px;right:40px;z-index:20;font-family:'IBM Plex Mono',monospace;font-size:9px;color:rgba(107,135,168,.35);letter-spacing:.1em;transition:opacity 3s;}

/* SHARED */
.st{font-family:'Cormorant Garamond',serif;font-size:clamp(22px,3vw,36px);font-weight:600;color:var(--white);margin-bottom:4px;line-height:1.0;}
.ss{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.18em;color:var(--muted);text-transform:uppercase;margin-bottom:20px;}
.tag{display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:.15em;
  padding:3px 8px;border:1px solid;text-transform:uppercase;margin-bottom:8px;}
.tag-r{border-color:var(--red);color:#e07070;}
.tag-a{border-color:var(--amber);color:#d4aa40;}
.tag-t{border-color:var(--terracotta);color:#d47060;}
.tag-g{border-color:var(--green);color:#5ecba1;}
.tag-b{border-color:#2563eb;color:#7aaddb;}

/* ── SLIDE 1 COVER ── */
.s1w{position:relative;z-index:3;flex:1;display:flex;flex-direction:column;justify-content:flex-end;padding:0 52px 72px;}
.s1ey{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.28em;color:var(--gold);text-transform:uppercase;margin-bottom:16px;opacity:0;animation:fup .8s .2s forwards;}
.s1ti{font-family:'Cormorant Garamond',serif;font-size:clamp(42px,6.5vw,88px);font-weight:600;color:var(--white);line-height:.9;margin-bottom:20px;opacity:0;animation:fup .8s .4s forwards;}
.s1ti em{color:var(--gold);font-style:italic;}
.s1ti span{color:var(--terracotta);}
.s1rl{width:72px;height:1px;background:linear-gradient(90deg,var(--terracotta),var(--gold));margin-bottom:18px;opacity:0;animation:expw .8s .6s forwards;}
.s1su{font-size:14px;font-weight:300;color:var(--muted);line-height:1.7;max-width:580px;margin-bottom:28px;opacity:0;animation:fup .8s .7s forwards;}
.s1pl{display:flex;gap:9px;flex-wrap:wrap;opacity:0;animation:fup .8s .9s forwards;}
.pill{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.13em;border:1px solid rgba(201,168,76,.3);color:var(--gold);padding:6px 14px;text-transform:uppercase;}
.pill-r{border-color:rgba(200,48,58,.4);color:var(--red);}
.s1dg{position:absolute;top:0;right:0;width:40%;height:100%;z-index:1;
  background:linear-gradient(135deg,transparent 0%,rgba(184,74,40,.025) 50%,rgba(184,74,40,.05) 100%);
  clip-path:polygon(22% 0,100% 0,100% 100%,0% 100%);}
.s1dl{position:absolute;top:0;right:0;width:40%;height:100%;z-index:1;
  border-left:1px solid rgba(184,74,40,.12);clip-path:polygon(22% 0,100% 0,100% 100%,0% 100%);}

/* ── SLIDE 2 CONTEXT ── */
.ctx-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;flex:1;}
.ctx-card{position:relative;padding:18px 17px;overflow:hidden;background:rgba(255,255,255,.018);
  border:1px solid rgba(255,255,255,.07);display:flex;flex-direction:column;gap:7px;transition:border-color .25s;}
.ctx-card:hover{border-color:rgba(201,168,76,.28);}
.ctx-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.cc1::before{background:linear-gradient(90deg,var(--terracotta),transparent);}
.cc2::before{background:linear-gradient(90deg,var(--amber),transparent);}
.cc3::before{background:linear-gradient(90deg,var(--red),transparent);}
.cc4::before{background:linear-gradient(90deg,#1e6fb5,transparent);}
.cc-num{position:absolute;bottom:10px;right:13px;font-family:'Cormorant Garamond',serif;font-size:50px;font-weight:700;color:rgba(255,255,255,.03);line-height:1;}
.cc-lbl{font-family:'IBM Plex Mono',monospace;font-size:8.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);}
.cc-hl{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;color:var(--white);line-height:1.25;letter-spacing:.02em;}
.cc-body{font-size:12px;font-weight:300;color:rgba(107,135,168,.85);line-height:1.6;flex:1;}

/* ── SLIDE 3 SENEGAL FRACTURE ── */
.tl{display:flex;flex-direction:column;max-width:660px;margin-bottom:16px;}
.tlr{display:flex;gap:16px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.05);}
.tldc{display:flex;flex-direction:column;align-items:center;min-width:11px;}
.tld{width:9px;height:9px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.tlln{flex:1;width:1px;background:rgba(201,168,76,.18);margin-top:4px;}
.tlyr{font-family:'IBM Plex Mono',monospace;font-size:9.5px;color:var(--gold);letter-spacing:.1em;margin-bottom:4px;}
.tltx{font-size:13px;font-weight:300;color:#8dadc8;line-height:1.65;}
.tltx strong{color:var(--white);}
.fracture-box{background:rgba(184,74,40,.06);border-left:3px solid var(--terracotta);padding:13px 17px;max-width:660px;}
.fracture-box p{font-size:13px;font-weight:300;color:#c09080;line-height:1.65;}
.fracture-box p strong{color:var(--white);}

/* ── SLIDE 4 GEOPOLITICS ── */
.geo-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px;flex:1;}
.geo-card{padding:18px 15px;display:flex;flex-direction:column;gap:8px;background:rgba(255,255,255,.02);
  border:1px solid rgba(255,255,255,.07);position:relative;overflow:hidden;}
.geo-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.gc-s::before{background:linear-gradient(90deg,#1e6fb5,transparent);}
.gc-b::before{background:linear-gradient(90deg,#d4af37,transparent);}
.gc-c::before{background:linear-gradient(90deg,var(--green),transparent);}
.gc-flag{font-size:22px;margin-bottom:2px;}
.gc-country{font-family:'IBM Plex Mono',monospace;font-size:8.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);}
.gc-title{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;color:var(--white);line-height:1.25;}
.gc-body{font-size:11.5px;font-weight:300;color:#7a9ab2;line-height:1.65;flex:1;}
.gc-alert{padding:8px 10px;font-size:11px;line-height:1.55;border-left:2px solid;margin-top:auto;}
.gca-b{border-color:#1e6fb5;color:#7aaddb;background:rgba(30,111,181,.05);}
.gca-g{border-color:var(--green);color:#5ecba1;background:rgba(13,122,74,.05);}
.gca-t{border-color:var(--terracotta);color:#d47060;background:rgba(184,74,40,.05);}

/* ── SLIDE 5 TERRORISM ── */
.terror-layout{display:flex;gap:16px;flex:1;}
.terror-left{flex:1;display:flex;flex-direction:column;gap:11px;}
.terror-right{width:240px;display:flex;flex-direction:column;gap:9px;}
.t-stat-row{display:flex;gap:10px;margin-bottom:4px;}
.t-stat{padding:13px 16px;flex:1;}
.ts-r{background:rgba(200,48,58,.07);border:1px solid rgba(200,48,58,.25);}
.ts-a{background:rgba(201,124,6,.06);border:1px solid rgba(201,124,6,.22);}
.ts-g{background:rgba(201,168,76,.06);border:1px solid rgba(201,168,76,.2);}
.t-sn{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:700;line-height:1;}
.tsn-r{color:var(--red);}.tsn-a{color:var(--amber);}.tsn-g{color:var(--gold);}
.t-sl{font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase;margin-top:3px;}
.t-body{font-size:13px;font-weight:300;color:#8dadc8;line-height:1.72;flex:1;}
.t-alert{background:rgba(200,48,58,.07);border:1px solid rgba(200,48,58,.28);border-left:3px solid var(--red);
  padding:12px 14px;font-size:12.5px;color:#c09090;line-height:1.6;}
.t-alert strong{color:var(--white);}
.group-card{padding:11px 13px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.07);
  display:flex;flex-direction:column;gap:5px;}
.gc-name{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);}
.gc-desc{font-size:11.5px;color:#6b87a8;line-height:1.5;}
.gc-zone{font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:.1em;color:var(--muted);}

/* ── SLIDE 6 ENCIRCLEMENT ── */
.encircle-wrap{display:flex;gap:16px;flex:1;}
.enc-left{flex:1;display:flex;flex-direction:column;gap:12px;}
.enc-right{width:230px;display:flex;flex-direction:column;gap:9px;}
.enc-intro{font-size:13.5px;font-weight:300;color:#8dadc8;line-height:1.72;margin-bottom:4px;}
.enc-intro strong{color:var(--white);}
.belt-card{padding:14px 16px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.07);
  display:flex;gap:12px;align-items:flex-start;position:relative;overflow:hidden;}
.belt-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;}
.bc-f::before{background:#4169e1;}.bc-s::before{background:var(--terracotta);}.bc-b::before{background:#d4af37;}.bc-c::before{background:var(--green);}
.bc-flag{font-size:18px;flex-shrink:0;padding-top:2px;}
.bc-country{font-family:'IBM Plex Mono',monospace;font-size:8.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;}
.bc-text{font-size:12.5px;font-weight:300;color:#7a9ab2;line-height:1.6;}
.bc-text strong{color:var(--white);}
.enc-finding{background:rgba(184,74,40,.08);border:1px solid rgba(184,74,40,.3);border-left:3px solid var(--terracotta);
  padding:13px 15px;font-size:12.5px;color:#c09080;line-height:1.65;}
.enc-finding strong{color:var(--white);}
.enc-stat{padding:13px 14px;text-align:center;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.07);}
.es-num{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:700;line-height:1;}
.es-lbl{font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase;margin-top:3px;}

/* ── SLIDE 7 RISK MATRIX ── */
.mx-wrap{display:flex;gap:18px;flex:1;align-items:flex-start;}
.mx-left{flex:1;min-width:0;}
.mx-right{width:215px;display:flex;flex-direction:column;gap:6px;}
.ax-lbl{font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:.2em;color:var(--muted);text-transform:uppercase;text-align:center;margin-bottom:5px;}
.mg{display:grid;grid-template-columns:68px repeat(5,1fr);gap:2px;}
.mc{height:38px;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;font-size:7.5px;text-align:center;line-height:1.3;transition:filter .2s;position:relative;cursor:default;}
.mc:hover{filter:brightness(1.3);}
.mch{background:transparent;color:var(--muted);font-size:7.5px;height:26px;}
.mcr{background:transparent;color:var(--muted);font-size:7.5px;justify-content:flex-end;padding-right:7px;text-align:right;}
.c1{background:rgba(16,185,129,.08);color:#6ee7b7;border:1px solid rgba(16,185,129,.15);}
.c2{background:rgba(16,185,129,.16);color:#34d399;border:1px solid rgba(16,185,129,.25);}
.c3{background:rgba(251,191,36,.1);color:#fbbf24;border:1px solid rgba(251,191,36,.2);}
.c4{background:rgba(245,158,11,.18);color:#f59e0b;border:1px solid rgba(245,158,11,.34);}
.c5{background:rgba(239,68,68,.14);color:#fca5a5;border:1px solid rgba(239,68,68,.27);}
.c6{background:rgba(239,68,68,.24);color:#f87171;border:1px solid rgba(239,68,68,.41);}
.c7{background:rgba(220,38,38,.36);color:#fca5a5;border:1px solid rgba(220,38,38,.6);font-weight:500;}
.rd{position:absolute;bottom:2px;right:3px;font-family:'IBM Plex Mono',monospace;font-size:7px;color:inherit;opacity:.9;font-weight:500;}
.rl{display:flex;gap:7px;align-items:flex-start;padding:7px 9px;background:rgba(255,255,255,.015);border-left:2px solid;}
.rlc{border-color:#ef4444;}.rlh{border-color:var(--amber);}.rlm{border-color:#fbbf24;}.rll{border-color:#10b981;}
.rlcd{font-family:'IBM Plex Mono',monospace;font-size:8px;color:var(--muted);white-space:nowrap;padding-top:1px;}
.rlt{font-size:11px;font-weight:600;color:var(--white);line-height:1.25;}
.rls{font-size:10px;color:var(--muted);line-height:1.4;}

/* ── SLIDE 8 CLOSE ── */
.cli{flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:0 52px;position:relative;z-index:3;}
.cltg{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.28em;color:var(--gold);text-transform:uppercase;margin-bottom:16px;}
.clti{font-family:'Cormorant Garamond',serif;font-size:clamp(38px,5.5vw,74px);font-weight:600;color:var(--white);line-height:.92;margin-bottom:16px;}
.clti em{color:var(--gold);font-style:italic;}.clti span{color:var(--terracotta);}
.clrl{width:54px;height:1px;background:linear-gradient(90deg,var(--terracotta),var(--gold));margin:0 auto 16px;}
.clbd{font-size:13.5px;font-weight:300;color:var(--muted);line-height:1.7;max-width:440px;margin-bottom:26px;}
.clcr{display:flex;gap:9px;flex-wrap:wrap;justify-content:center;margin-bottom:26px;}
.clcd{padding:10px 17px;border:1px solid rgba(201,168,76,.22);min-width:130px;}
.clcl{font-family:'IBM Plex Mono',monospace;font-size:8.5px;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;margin-bottom:4px;}
.clcv{font-size:13px;color:var(--gold2);}
.clft{font-family:'IBM Plex Mono',monospace;font-size:9px;color:rgba(107,135,168,.3);letter-spacing:.1em;line-height:1.8;}

/* ANIMATIONS */
@keyframes fup{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
@keyframes expw{from{opacity:0;width:0;}to{opacity:1;width:72px;}}
@keyframes sin{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.slide.active .ctx-card,.slide.active .geo-card,.slide.active .belt-card,.slide.active .group-card,.slide.active .rl{animation:sin .45s both;}
.slide.active .ctx-card:nth-child(1),.slide.active .geo-card:nth-child(1),.slide.active .belt-card:nth-child(1),.slide.active .group-card:nth-child(1){animation-delay:.04s;}
.slide.active .ctx-card:nth-child(2),.slide.active .geo-card:nth-child(2),.slide.active .belt-card:nth-child(2),.slide.active .group-card:nth-child(2){animation-delay:.12s;}
.slide.active .ctx-card:nth-child(3),.slide.active .geo-card:nth-child(3),.slide.active .belt-card:nth-child(3),.slide.active .group-card:nth-child(3){animation-delay:.2s;}
.slide.active .ctx-card:nth-child(4),.slide.active .belt-card:nth-child(4),.slide.active .group-card:nth-child(4){animation-delay:.28s;}
.slide.active .rl:nth-child(1){animation-delay:.04s;}.slide.active .rl:nth-child(2){animation-delay:.09s;}
.slide.active .rl:nth-child(3){animation-delay:.14s;}.slide.active .rl:nth-child(4){animation-delay:.19s;}
.slide.active .rl:nth-child(5){animation-delay:.24s;}.slide.active .rl:nth-child(6){animation-delay:.29s;}
.slide.active .rl:nth-child(7){animation-delay:.34s;}.slide.active .rl:nth-child(8){animation-delay:.39s;}
.slide.active .rl:nth-child(9){animation-delay:.44s;}
.slide.active .tlr{animation:sin .38s both;}
.slide.active .tlr:nth-child(1){animation-delay:.05s;}.slide.active .tlr:nth-child(2){animation-delay:.16s;}.slide.active .tlr:nth-child(3){animation-delay:.27s;}.slide.active .tlr:nth-child(4){animation-delay:.38s;}
.slide.active .t-stat-row{animation:sin .45s .08s both;}
@media(max-width:700px){.si,.s1w,.cli{padding:20px 16px 24px;}.ctx-grid,.geo-grid,.terror-layout,.encircle-wrap,.mx-wrap{flex-direction:column;grid-template-columns:1fr;}.mx-right,.terror-right,.enc-right{width:100%;}}
</style>
</head>
<body>
<div class="deck" id="deck">
<div class="progress-bar" id="pb"></div>
<div class="snum" id="sn">01 / 08</div>
<div class="kh" id="kh">&#8592; &#8594;</div>
<div class="nav"><div class="nav-btn" id="prev">&#8592;</div><div class="nav-dots" id="nd"></div><div class="nav-btn" id="next">&#8594;</div></div>

<!-- ═══ SLIDE 1 COVER ═══ -->
<div class="slide active" id="s0">
  <canvas class="bgc" id="c0"></canvas>
  <div class="ghost" style="font-size:26vw;bottom:-5%;left:-2%;">SN</div>
  <div class="s1dg"></div><div class="s1dl"></div>
  <div class="bk bk-tl"></div><div class="bk bk-tr"></div><div class="bk bk-bl"></div><div class="bk bk-br"></div>
  <div class="s1w">
    <div class="s1ey">SRM Grand Lakes &amp; Africa &middot; Analyse Régionale Spéciale</div>
